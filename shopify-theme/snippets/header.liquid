<header class="site-header">
  <div class="header-inner">

    <!-- Logo -->
    <a href="{{ routes.root_url }}" class="header-logo">
      🐾 {{ shop.name | default: 'PetShop' }}<span>.</span>
    </a>

    <!-- Nav principal -->
    <nav class="site-nav" role="navigation" aria-label="Navegación principal">

      <div class="nav-item">
        <a href="{{ routes.root_url }}" class="nav-link">Inicio</a>
      </div>

      <!-- GATOS mega menu -->
      <div class="nav-item">
        <a href="{{ collections['gatos'].url | default: routes.all_products_collection_url }}" class="nav-link" aria-haspopup="true">
          Gatos
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </a>
        <div class="mega-menu" role="region" aria-label="Categorías para Gatos">
          <div class="mega-menu-header">
            <div class="mega-menu-icon cat-icon-bg">🐱</div>
            <div>
              <div class="mega-menu-title">Para Gatos</div>
              <div class="mega-menu-subtitle">Todo lo que tu felino necesita</div>
            </div>
          </div>
          <div class="mega-menu-grid">
            <a href="{{ collections['gatos-croquetas'].url | default: routes.all_products_collection_url }}" class="mega-menu-item">
              <div class="item-icon cat-item-bg">🥣</div>
              <div>
                <div class="item-name">Croquetas</div>
                <div class="item-desc">Alimento seco balanceado</div>
              </div>
            </a>
            <a href="{{ collections['gatos-alimento-seco'].url | default: routes.all_products_collection_url }}" class="mega-menu-item">
              <div class="item-icon cat-item-bg">🌾</div>
              <div>
                <div class="item-name">Alimento Seco</div>
                <div class="item-desc">Nutrición completa y natural</div>
              </div>
            </a>
            <a href="{{ collections['gatos-humedo'].url | default: routes.all_products_collection_url }}" class="mega-menu-item">
              <div class="item-icon cat-item-bg">🥩</div>
              <div>
                <div class="item-name">Húmedo</div>
                <div class="item-desc">Patés y gelatinas premium</div>
              </div>
            </a>
            <a href="{{ collections['gatos-premios'].url | default: routes.all_products_collection_url }}" class="mega-menu-item">
              <div class="item-icon cat-item-bg">⭐</div>
              <div>
                <div class="item-name">Premios</div>
                <div class="item-desc">Snacks y golosinas</div>
              </div>
            </a>
            <a href="{{ collections['gatos-suplementos'].url | default: routes.all_products_collection_url }}" class="mega-menu-item">
              <div class="item-icon cat-item-bg">💊</div>
              <div>
                <div class="item-name">Suplementos</div>
                <div class="item-desc">Vitaminas y cuidado</div>
              </div>
            </a>
          </div>
          <div class="mega-menu-footer">
            <a href="{{ collections['gatos'].url | default: routes.all_products_collection_url }}" class="see-all-btn">
              Ver todo para Gatos →
            </a>
          </div>
        </div>
      </div>

      <!-- PERROS mega menu -->
      <div class="nav-item">
        <a href="{{ collections['perros'].url | default: routes.all_products_collection_url }}" class="nav-link" aria-haspopup="true">
          Perros
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </a>
        <div class="mega-menu" role="region" aria-label="Categorías para Perros">
          <div class="mega-menu-header">
            <div class="mega-menu-icon dog-icon-bg">🐶</div>
            <div>
              <div class="mega-menu-title">Para Perros</div>
              <div class="mega-menu-subtitle">La mejor nutrición para tu compañero</div>
            </div>
          </div>
          <div class="mega-menu-grid">
            <a href="{{ collections['perros-croquetas'].url | default: routes.all_products_collection_url }}" class="mega-menu-item">
              <div class="item-icon dog-item-bg">🥣</div>
              <div>
                <div class="item-name">Croquetas</div>
                <div class="item-desc">Alimento seco balanceado</div>
              </div>
            </a>
            <a href="{{ collections['perros-alimento-seco'].url | default: routes.all_products_collection_url }}" class="mega-menu-item">
              <div class="item-icon dog-item-bg">🌾</div>
              <div>
                <div class="item-name">Alimento Seco</div>
                <div class="item-desc">Nutrición completa y natural</div>
              </div>
            </a>
            <a href="{{ collections['perros-humedo'].url | default: routes.all_products_collection_url }}" class="mega-menu-item">
              <div class="item-icon dog-item-bg">🥩</div>
              <div>
                <div class="item-name">Húmedo</div>
                <div class="item-desc">Latas y bolsitas premium</div>
              </div>
            </a>
            <a href="{{ collections['perros-premios'].url | default: routes.all_products_collection_url }}" class="mega-menu-item">
              <div class="item-icon dog-item-bg">⭐</div>
              <div>
                <div class="item-name">Premios</div>
                <div class="item-desc">Snacks y golosinas</div>
              </div>
            </a>
            <a href="{{ collections['perros-suplementos'].url | default: routes.all_products_collection_url }}" class="mega-menu-item">
              <div class="item-icon dog-item-bg">💊</div>
              <div>
                <div class="item-name">Suplementos</div>
                <div class="item-desc">Articulaciones, piel y más</div>
              </div>
            </a>
          </div>
          <div class="mega-menu-footer">
            <a href="{{ collections['perros'].url | default: routes.all_products_collection_url }}" class="see-all-btn" style="color: var(--forest-light);">
              Ver todo para Perros →
            </a>
          </div>
        </div>
      </div>

      <div class="nav-item">
        <a href="{{ blogs['noticias'].url | default: routes.root_url }}" class="nav-link">Blog</a>
      </div>

      <div class="nav-item">
        <a href="{{ pages['contacto'].url | default: pages['contact'].url | default: routes.root_url }}" class="nav-link">Contacto</a>
      </div>

    </nav>

    <!-- Header actions -->
    <div class="header-actions">

      {% if shop.customer_accounts_enabled %}
        <a href="/account" class="icon-btn" aria-label="Mi cuenta">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </a>
      {% endif %}

      <a href="{{ routes.search_url }}" class="icon-btn" aria-label="Buscar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </a>

      <a href="{{ routes.cart_url }}" class="icon-btn" aria-label="Carrito">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="cart-badge">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>

    </div>
  </div>
</header>
