<section class="account-page">
  <div class="container">
    <div class="account-card">
      <div style="text-align:center; font-size:48px; margin-bottom:16px;">🐾</div>
      <h1 class="account-card-title">Crea tu cuenta</h1>
      <p class="account-card-sub">Únete y accede a ofertas exclusivas para tus mascotas</p>
      {%- form 'create_customer' -%}
        {%- if form.errors -%}
          <div style="background:#FEE; border: 1px solid var(--terracotta); border-radius: var(--radius); padding: 12px 16px; margin-bottom:20px; font-size:13.5px; color: var(--terracotta);">{{ form.errors | default_errors }}</div>
        {%- endif -%}
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:18px;">
          <div class="form-field" style="margin-bottom:0;"><label class="form-label" for="FirstName">Nombre</label><input type="text" name="customer[first_name]" id="FirstName" class="form-input" placeholder="Juan" autocorrect="off"></div>
          <div class="form-field" style="margin-bottom:0;"><label class="form-label" for="LastName">Apellido</label><input type="text" name="customer[last_name]" id="LastName" class="form-input" placeholder="García" autocorrect="off"></div>
        </div>
        <div class="form-field"><label class="form-label" for="RegisterEmail">Correo electrónico</label><input type="email" name="customer[email]" id="RegisterEmail" class="form-input" placeholder="tu@correo.com" required autocorrect="off"></div>
        <div class="form-field"><label class="form-label" for="RegisterPassword">Contraseña</label><input type="password" name="customer[password]" id="RegisterPassword" class="form-input" placeholder="Mínimo 8 caracteres" required></div>
        <button type="submit" class="form-submit">Crear cuenta gratuita</button>
      {%- endform -%}
      <div class="account-switch">¿Ya tienes cuenta? <a href="/account/login">Inicia sesión</a></div>
    </div>
  </div>
</section>
