<!-- WHY US -->

<section class="why-us">
  <div class="container">
    <p class="section-label">¿Por qué elegirnos?</p>
    <h2 class="section-title">El bienestar de tu mascota, nuestra misión</h2>

    <div class="benefits-grid">
      <div class="benefit-card">
        <div class="benefit-icon">🌿</div>
        <div class="benefit-title">100% Natural</div>
        <p class="benefit-text">Todos nuestros productos están libres de conservadores artificiales, colorantes y saborizantes.</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-icon">👨‍⚕️</div>
        <div class="benefit-title">Aprobado por Veterinarios</div>
        <p class="benefit-text">Cada producto es revisado y recomendado por nutricionistas veterinarios especializados.</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-icon">🚚</div>
        <div class="benefit-title">Envío Rápido</div>
        <p class="benefit-text">Entregamos en 24-48 horas en todo el país. Envío gratis en compras mayores a $599.</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-icon">💯</div>
        <div class="benefit-title">Garantía de Satisfacción</div>
        <p class="benefit-text">Si tu mascota no lo ama, te devolvemos tu dinero. Así de seguros estamos de nuestra calidad.</p>
      </div>
    </div>
  </div>
</section>

<!-- NEWSLETTER -->
<section class="newsletter">
  <div class="container">
    <div class="newsletter-inner">
      <p class="section-label" style="text-align:center">Newsletter</p>
      <h2 class="section-title">Consejos y ofertas exclusivas</h2>
      <p class="section-desc" style="margin: 0 auto 32px;">Suscríbete y recibe tips de nutrición, descuentos especiales y novedades para tu mascota.</p>

      {%- form 'customer', id: 'ContactFooter' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter-form">
          <input
            type="email"
            name="contact[email]"
            class="newsletter-input"
            placeholder="Tu correo electrónico"
            autocorrect="off"
            autocapitalize="off"
            required
          >
          <button type="submit" class="newsletter-btn">Suscribirme 🐾</button>
        </div>
      {%- endform -%}
    </div>
  </div>
</section>
