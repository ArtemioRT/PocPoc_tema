<article class="article-page">
  <div class="container">

    <div class="article-breadcrumb">
      <a href="/">Inicio</a><span>/</span>
      <a href="{{ blog.url }}">{{ blog.title }}</a><span>/</span>
      <span>{{ article.title | truncatewords: 5 }}</span>
    </div>

    <div class="article-layout">

      <div class="article-main-col">
        <div class="article-tags-row">
          {%- for tag in article.tags -%}
            <span class="article-tag-pill">{{ tag }}</span>
          {%- else -%}
            <span class="article-tag-pill">Nutrición</span>
            <span class="article-tag-pill">Gatos</span>
          {%- endfor -%}
        </div>

        <h1 class="article-page-title">{{ article.title }}</h1>

        <div class="article-author-row">
          <div class="author-avatar">{{ article.author | slice: 0 }}{{ article.author | split: ' ' | last | slice: 0 }}</div>
          <div>
            <div class="author-name">{{ article.author | default: 'Equipo PetShop' }}</div>
            <div class="article-date">{{ article.published_at | date: '%d de %B de %Y' }} · {{ article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min de lectura</div>
          </div>
          <div class="article-share">
            <button class="share-btn" onclick="navigator.share ? navigator.share({title:'{{ article.title | escape }}', url:window.location.href}) : copyLink()" aria-label="Compartir artículo">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
              Compartir
            </button>
          </div>
        </div>

        {%- if article.image -%}
          <div class="article-hero-img">
            <img src="{{ article.image | img_url: '1000x600' }}" alt="{{ article.image.alt | default: article.title | escape }}">
          </div>
        {%- else -%}
          <div class="article-hero-img article-hero-placeholder">
            <span style="font-size:100px">🐾</span>
          </div>
        {%- endif -%}

        <div class="article-content rte">
          {{ article.content }}
        </div>

        <div class="article-footer">
          <div class="article-tags-footer">
            <span>Etiquetas:</span>
            {%- for tag in article.tags -%}
              <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="article-tag-link">{{ tag }}</a>
            {%- else -%}
              <a href="#" class="article-tag-link">Nutrición</a>
              <a href="#" class="article-tag-link">Mascotas</a>
            {%- endfor -%}
          </div>
        </div>

        <!-- Comments -->
        {%- if blog.comments_enabled? -%}
        <div class="article-comments">
          <h3 class="comments-title">Comentarios ({{ article.comments_count }})</h3>
          {%- for comment in article.comments -%}
            <div class="comment-card">
              <div class="comment-author-row">
                <div class="comment-avatar">{{ comment.author | slice: 0 }}</div>
                <div>
                  <div class="comment-author">{{ comment.author }}</div>
                  <div class="comment-date">{{ comment.created_at | date: '%d %b %Y' }}</div>
                </div>
              </div>
              <p class="comment-body">{{ comment.content }}</p>
            </div>
          {%- endfor -%}

          {%- form 'new_comment', article -%}
            <div class="comment-form">
              <h4>Deja un comentario</h4>
              <div class="comment-form-row">
                <input type="text" name="comment[author]" placeholder="Tu nombre" class="comment-input" required>
                <input type="email" name="comment[email]" placeholder="Tu email" class="comment-input" required>
              </div>
              <textarea name="comment[body]" placeholder="Tu comentario..." class="comment-textarea" rows="4" required></textarea>
              <button type="submit" class="submit-review-btn">Publicar comentario</button>
            </div>
          {%- endform -%}
        </div>
        {%- endif -%}
      </div>

      <!-- SIDEBAR -->
      <aside class="article-sidebar">
        <div class="sidebar-widget">
          <div class="sidebar-widget-title">🔥 Artículos populares</div>
          {%- for a in blog.articles limit: 4 -%}
            {%- unless a.id == article.id -%}
            <a href="{{ a.url }}" class="sidebar-post">
              <div class="sidebar-post-img">
                {%- if a.image -%}<img src="{{ a.image | img_url: '60x60' }}" alt="{{ a.title | escape }}">{%- else -%}<span>🐾</span>{%- endif -%}
              </div>
              <div>
                <div class="sidebar-post-title">{{ a.title | truncatewords: 8 }}</div>
                <div class="sidebar-post-date">{{ a.published_at | date: '%d %b %Y' }}</div>
              </div>
            </a>
            {%- endunless -%}
          {%- else -%}
            {%- assign sidebar_titles = 'Alimento para gatitos: guía de inicio,Los mejores premios naturales,Cómo cuidar las articulaciones de tu perro' | split: ',' -%}
            {%- for t in sidebar_titles -%}
              <a href="#" class="sidebar-post">
                <div class="sidebar-post-img"><span>🐾</span></div>
                <div><div class="sidebar-post-title">{{ t }}</div><div class="sidebar-post-date">Mar 2026</div></div>
              </a>
            {%- endfor -%}
          {%- endfor -%}
        </div>

        <div class="sidebar-widget sidebar-cta">
          <div style="font-size:36px; margin-bottom:10px;">🐾</div>
          <div class="sidebar-widget-title">¿Necesitas ayuda?</div>
          <p>Nuestros expertos en nutrición animal están aquí para orientarte.</p>
          <a href="{{ pages['contacto'].url | default: pages['contact'].url | default: routes.root_url }}" class="btn-primary" style="background:var(--forest); color:white; width:100%; justify-content:center; margin-top:14px;">Contactar experto</a>
        </div>
      </aside>
    </div>
  </div>
</article>

<script>
  function copyLink() {
    navigator.clipboard.writeText(window.location.href).then(() => alert('¡Enlace copiado!'));
  }
</script>
