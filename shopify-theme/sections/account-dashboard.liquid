<section class="account-page">
  <div class="container">
    <div style="display:grid; grid-template-columns: 240px 1fr; gap:32px; align-items:start;">
      <div style="background:var(--white); border-radius:var(--radius-lg); border:1px solid var(--cream-dark); overflow:hidden; position:sticky; top:90px;">
        <div style="background:var(--forest); padding:28px 20px; color:white; text-align:center;">
          <div style="width:60px;height:60px;border-radius:50%;background:rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:700;margin:0 auto 10px;">{{ customer.first_name | slice: 0 }}{{ customer.last_name | slice: 0 }}</div>
          <div style="font-family:var(--font-display);font-size:17px;font-weight:700;">{{ customer.name }}</div>
          <div style="font-size:12px;opacity:0.75;margin-top:3px;">{{ customer.email }}</div>
        </div>
        <nav style="padding:12px 0;">
          <a href="/account" style="display:flex;align-items:center;gap:10px;padding:11px 18px;font-size:13.5px;font-weight:600;color:var(--forest);background:var(--cream);">📦 Mis pedidos</a>
          <a href="/account/addresses" style="display:flex;align-items:center;gap:10px;padding:11px 18px;font-size:13.5px;font-weight:500;color:var(--charcoal);transition:background 0.2s;">📍 Mis direcciones</a>
          <a href="/account/logout" style="display:flex;align-items:center;gap:10px;padding:11px 18px;font-size:13.5px;font-weight:500;color:var(--terracotta);">🚪 Cerrar sesión</a>
        </nav>
      </div>
      <div>
        <div style="margin-bottom:32px;">
          <p class="section-label">Mi cuenta</p>
          <h1 class="section-title" style="font-size:28px;">¡Hola, {{ customer.first_name }}! 🐾</h1>
        </div>
        {%- if customer.orders.size > 0 -%}
          <div style="background:var(--white);border-radius:var(--radius-lg);border:1px solid var(--cream-dark);overflow:hidden;">
            <div style="padding:20px 24px;border-bottom:1px solid var(--cream-dark);font-weight:700;font-size:15px;">Historial de pedidos</div>
            {%- for order in customer.orders -%}
              <div style="display:grid;grid-template-columns:auto 1fr auto auto;align-items:center;gap:16px;padding:16px 24px;border-bottom:1px solid var(--cream-dark);">
                <div style="font-size:13px;font-weight:700;color:var(--forest);">#{{ order.order_number }}</div>
                <div><div style="font-size:13px;font-weight:600;">{{ order.name }}</div><div style="font-size:12px;color:var(--gray);">{{ order.created_at | date: '%d/%m/%Y' }} · {{ order.line_items.size }} artículo{% if order.line_items.size != 1 %}s{% endif %}</div></div>
                <span style="padding:4px 12px;border-radius:100px;font-size:11px;font-weight:700;background:{%- if order.financial_status == 'paid' -%}var(--forest){%- else -%}var(--amber){%- endif -%};color:white;">{{ order.financial_status }}</span>
                <span style="font-family:var(--font-display);font-weight:700;">{{ order.total_price | money }}</span>
              </div>
            {%- endfor -%}
          </div>
        {%- else -%}
          <div style="text-align:center;padding:60px 20px;background:var(--white);border-radius:var(--radius-lg);border:1px solid var(--cream-dark);">
            <div style="font-size:60px;margin-bottom:14px;">📦</div>
            <h3 style="font-family:var(--font-display);font-size:22px;font-weight:700;margin-bottom:8px;">Aún no tienes pedidos</h3>
            <p style="color:var(--gray);margin-bottom:24px;">¡Empieza a comprar para tus mascotas!</p>
            <a href="{{ routes.all_products_collection_url }}" class="btn-primary" style="background:var(--forest);color:white;display:inline-flex;padding:12px 24px;border-radius:100px;font-weight:700;font-size:14px;">Explorar productos</a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
