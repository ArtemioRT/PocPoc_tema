<section class="product-page">
  <div class="container">

    <div class="product-breadcrumb">
      <a href="/">Inicio</a>
      <span>/</span>
      {%- if product.collections.first -%}
        <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
        <span>/</span>
      {%- endif -%}
      <span>{{ product.title }}</span>
    </div>

    <div class="product-layout">

      <!-- GALLERY -->
      <div class="product-gallery">
        <div class="gallery-thumbnails" id="gallery-thumbs">
          {%- if product.images.size > 0 -%}
            {%- for image in product.images limit: 5 -%}
              <button
                class="thumb-btn {% if forloop.first %}active{% endif %}"
                onclick="setMainImage(this, '{{ image | img_url: '800x800' }}')"
                aria-label="Ver imagen {{ forloop.index }}"
              >
                <img src="{{ image | img_url: '100x100' }}" alt="{{ image.alt | default: product.title }}" loading="lazy">
              </button>
            {%- endfor -%}
          {%- else -%}
            {%- assign demo_thumbs = '🥣,🌾,🥩,⭐,💊' | split: ',' -%}
            {%- for t in demo_thumbs -%}
              <button class="thumb-btn {% if forloop.first %}active{% endif %}" onclick="setMainEmoji(this, '{{ t }}')" aria-label="Vista {{ forloop.index }}">
                <span style="font-size:32px">{{ t }}</span>
              </button>
            {%- endfor -%}
          {%- endif -%}
        </div>

        <div class="gallery-main">
          <div class="gallery-main-inner" id="gallery-main">
            {%- if product.featured_image -%}
              <img
                id="main-product-img"
                src="{{ product.featured_image | img_url: '800x800' }}"
                alt="{{ product.featured_image.alt | default: product.title | escape }}"
              >
            {%- else -%}
              <span id="main-product-emoji" style="font-size:120px">🥣</span>
            {%- endif -%}
            <div class="gallery-zoom-hint">🔍 Zoom al pasar el cursor</div>
          </div>
          <div class="gallery-badges">
            {%- if product.tags contains 'nuevo' -%}<span class="product-badge badge-new">Nuevo</span>{%- endif -%}
            {%- if product.compare_at_price > product.price -%}
              <span class="product-badge badge-sale">-{{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}% OFF</span>
            {%- endif -%}
          </div>
        </div>
      </div>

      <!-- PRODUCT INFO -->
      <div class="product-info-col">

        <div class="product-info-header">
          <div class="product-vendor-tag">{{ product.vendor }}</div>
          <h1 class="product-detail-title">{{ product.title }}</h1>

          <div class="product-rating-row">
            <div class="stars-display">★★★★★</div>
            <span class="rating-count">4.9 (127 reseñas)</span>
            <a href="#reviews" class="rating-link">Ver reseñas</a>
          </div>
        </div>

        <div class="product-price-block">
          <span class="product-detail-price">{{ product.price | money }}</span>
          {%- if product.compare_at_price > product.price -%}
            <span class="product-detail-old-price">{{ product.compare_at_price | money }}</span>
            <span class="product-saving">Ahorras {{ product.compare_at_price | minus: product.price | money }}</span>
          {%- endif -%}
        </div>

        {%- unless product.has_only_default_variant -%}
        <div class="product-variants">
          {%- for option in product.options_with_values -%}
            <div class="variant-group">
              <div class="variant-label">{{ option.name }}: <strong>{{ option.selected_value }}</strong></div>
              <div class="variant-options">
                {%- for value in option.values -%}
                  <button
                    class="variant-btn {% if option.selected_value == value %}active{% endif %}"
                    onclick="selectVariant(this)"
                    data-value="{{ value }}"
                  >
                    {{ value }}
                  </button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
        {%- else -%}
        <!-- Demo variants (peso / tamaño) -->
        <div class="product-variants">
          <div class="variant-group">
            <div class="variant-label">Presentación: <strong>1.5 kg</strong></div>
            <div class="variant-options">
              <button class="variant-btn active" onclick="selectVariant(this)">500g</button>
              <button class="variant-btn" onclick="selectVariant(this)">1.5 kg</button>
              <button class="variant-btn" onclick="selectVariant(this)">3 kg</button>
              <button class="variant-btn" onclick="selectVariant(this)">7 kg</button>
              <button class="variant-btn out-of-stock" disabled>15 kg</button>
            </div>
          </div>
        </div>
        {%- endunless -%}

        <div class="product-qty-add">
          <div class="qty-selector">
            <button class="qty-btn" onclick="changeQty(-1)" aria-label="Reducir cantidad">−</button>
            <input type="number" id="qty-input" class="qty-input" value="1" min="1" max="99" aria-label="Cantidad">
            <button class="qty-btn" onclick="changeQty(1)" aria-label="Aumentar cantidad">+</button>
          </div>
          <button class="add-to-cart-btn" onclick="addToCartMain()">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            Agregar al carrito
          </button>
        </div>

        <button class="buy-now-btn">⚡ Comprar ahora</button>

        <div class="product-trust-badges">
          <div class="trust-item">🚚 <span>Envío gratis +$599</span></div>
          <div class="trust-item">🔄 <span>Devolución 30 días</span></div>
          <div class="trust-item">🔒 <span>Pago seguro</span></div>
          <div class="trust-item">👨‍⚕️ <span>Aprobado veterinarios</span></div>
        </div>

        <div class="product-tabs-nav">
          <button class="product-tab-btn active" onclick="switchProductTab('descripcion', this)">Descripción</button>
          <button class="product-tab-btn" onclick="switchProductTab('ingredientes', this)">Ingredientes</button>
          <button class="product-tab-btn" onclick="switchProductTab('analisis', this)">Análisis</button>
        </div>

        <div class="product-tab-content active" id="tab-descripcion">
          <div class="product-description">
            {%- if product.description != blank -%}
              {{ product.description }}
            {%- else -%}
              <p>Alimento premium formulado especialmente para las necesidades nutricionales de tu mascota. Con ingredientes naturales de alta calidad, sin conservadores artificiales ni colorantes.</p>
              <ul style="margin-top:12px; padding-left:18px; display:flex; flex-direction:column; gap:6px;">
                <li>✅ Alto contenido en proteína animal</li>
                <li>✅ Sin granos ni cereales añadidos</li>
                <li>✅ Rico en Omega-3 y Omega-6</li>
                <li>✅ Apoya la salud digestiva</li>
                <li>✅ Enriquecido con vitaminas y minerales</li>
              </ul>
            {%- endif -%}
          </div>
        </div>

        <div class="product-tab-content" id="tab-ingredientes">
          <p style="font-size:14px; color: var(--gray); line-height:1.8;">Pollo deshidratado (35%), arroz integral, grasa de pollo, proteína de guisante, aceite de salmón, fibra de achicoria, taurina, vitaminas (A, D3, E, B1, B2, B5, B6, B12), minerales (calcio, fósforo, sodio, potasio, magnesio, zinc, hierro, manganeso, cobre, yodo, selenio).</p>
        </div>

        <div class="product-tab-content" id="tab-analisis">
          <div class="analysis-table">
            <div class="analysis-row"><span>Proteína cruda</span><span>32%</span></div>
            <div class="analysis-row"><span>Grasa cruda</span><span>18%</span></div>
            <div class="analysis-row"><span>Fibra cruda</span><span>3.5%</span></div>
            <div class="analysis-row"><span>Humedad</span><span>10%</span></div>
            <div class="analysis-row"><span>Cenizas</span><span>7%</span></div>
            <div class="analysis-row"><span>Calcio</span><span>1.2%</span></div>
            <div class="analysis-row"><span>Fósforo</span><span>0.9%</span></div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<script>
  function setMainImage(btn, url) {
    document.querySelectorAll('.thumb-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const img = document.getElementById('main-product-img');
    if (img) { img.src = url; img.style.opacity='0'; setTimeout(()=>img.style.opacity='1',50); }
  }
  function setMainEmoji(btn, emoji) {
    document.querySelectorAll('.thumb-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const el = document.getElementById('main-product-emoji');
    if (el) { el.style.opacity='0'; el.textContent=emoji; setTimeout(()=>el.style.opacity='1',50); }
  }
  function selectVariant(btn) {
    btn.closest('.variant-options').querySelectorAll('.variant-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    btn.closest('.variant-group').querySelector('strong').textContent = btn.dataset.value || btn.textContent;
  }
  function changeQty(delta) {
    const inp = document.getElementById('qty-input');
    inp.value = Math.max(1, Math.min(99, parseInt(inp.value) + delta));
  }
  function addToCartMain() {
    const btn = document.querySelector('.add-to-cart-btn');
    const orig = btn.innerHTML;
    btn.innerHTML = '✓ Agregado al carrito';
    btn.style.background = 'var(--forest)';
    setTimeout(() => { btn.innerHTML = orig; btn.style.background = ''; }, 2000);
  }
  function switchProductTab(id, btn) {
    document.querySelectorAll('.product-tab-btn').forEach(b=>b.classList.remove('active'));
    document.querySelectorAll('.product-tab-content').forEach(c=>c.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-'+id).classList.add('active');
  }
</script>
