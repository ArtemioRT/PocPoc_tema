<!-- HERO SECTION -->
<section class="hero" aria-label="Banner principal">
  <div class="hero-bg"></div>
  <div class="hero-pattern"></div>
  <div class="hero-paw-bg"></div>

  <div class="hero-content">
    <div class="hero-text">
      <div class="hero-badge">
        🐾 Nutrición Natural Premium
      </div>
      <h1 class="hero-title">
        Todo para el<br>bienestar de<br><em>tu mascota</em>
      </h1>
      <p class="hero-desc">
        Alimentos premium, suplementos y premios seleccionados por veterinarios para mantener a tu gato o perro feliz y saludable.
      </p>
      <div class="hero-actions">
        <a href="{{ collections['gatos'].url | default: routes.all_products_collection_url }}" class="btn-primary">
          🐱 Para Gatos
        </a>
        <a href="{{ collections['perros'].url | default: routes.all_products_collection_url }}" class="btn-outline">
          🐶 Para Perros
        </a>
      </div>
      <div class="hero-stats">
        <div>
          <div class="stat-num">+500</div>
          <div class="stat-label">Productos</div>
        </div>
        <div>
          <div class="stat-num">100%</div>
          <div class="stat-label">Natural</div>
        </div>
        <div>
          <div class="stat-num">4.9★</div>
          <div class="stat-label">Calificación</div>
        </div>
      </div>
    </div>

    <div class="hero-cards">
      <a href="{{ collections['gatos'].url | default: routes.all_products_collection_url }}" class="pet-card pet-card-cats">
        <div class="pet-emoji">🐱</div>
        <div class="pet-card-name">Gatos</div>
        <div class="pet-card-count">5 categorías</div>
      </a>
      <a href="{{ collections['perros'].url | default: routes.all_products_collection_url }}" class="pet-card pet-card-dogs">
        <div class="pet-emoji">🐶</div>
        <div class="pet-card-name">Perros</div>
        <div class="pet-card-count">5 categorías</div>
      </a>
    </div>
  </div>
</section>
