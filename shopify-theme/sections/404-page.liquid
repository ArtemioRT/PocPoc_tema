<section class="error-page">
  <div class="container">
    <div class="error-page-inner">
      <div class="error-emoji">🐾</div>
      <div class="error-code">404</div>
      <h1 class="error-title">¡Ups! Página no encontrada</h1>
      <p class="error-desc">Parece que esta página salió a pasear y no regresó. No te preocupes, podemos ayudarte a encontrar lo que buscas.</p>
      <div class="error-actions">
        <a href="{{ routes.root_url }}" class="btn-primary" style="background:var(--forest); color:white;">🏠 Ir al inicio</a>
        <a href="{{ collections['gatos'].url | default: routes.all_products_collection_url }}" class="btn-primary" style="background:var(--terracotta); color:white;">🐱 Ver Gatos</a>
        <a href="{{ collections['perros'].url | default: routes.all_products_collection_url }}" class="btn-primary" style="background:var(--forest-light); color:white;">🐶 Ver Perros</a>
      </div>
    </div>
  </div>
</section>
