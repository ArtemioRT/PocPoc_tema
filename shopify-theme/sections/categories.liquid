<!-- SECCIÓN DE CATEGORÍAS CON TABS -->
<section class="pet-tabs" aria-labelledby="categories-title">
  <div class="container">

    <div class="section-header">
      <div>
        <p class="section-label">Explora por mascota</p>
        <h2 class="section-title" id="categories-title">¿Para quién estás comprando?</h2>
      </div>
    </div>

    <div class="tabs-wrapper" role="tablist" aria-label="Seleccionar mascota">
      <button
        class="tab-btn active"
        role="tab"
        aria-selected="true"
        aria-controls="tab-gatos"
        id="btn-gatos"
        onclick="switchTab('gatos', this)"
      >
        🐱 Para Gatos
      </button>
      <button
        class="tab-btn"
        role="tab"
        aria-selected="false"
        aria-controls="tab-perros"
        id="btn-perros"
        onclick="switchTab('perros', this)"
      >
        🐶 Para Perros
      </button>
    </div>

    <!-- Panel GATOS -->
    <div class="tab-panel active cat-theme" id="tab-gatos" role="tabpanel" aria-labelledby="btn-gatos">
      <div class="categories-grid">

        <a href="{{ collections['gatos-croquetas'].url | default: routes.all_products_collection_url }}" class="category-card">
          <div class="category-icon-wrap">🥣</div>
          <div class="category-name">Croquetas</div>
          <div class="category-count">Alimento seco balanceado</div>
          <div class="category-arrow">Ver más →</div>
        </a>

        <a href="{{ collections['gatos-alimento-seco'].url | default: routes.all_products_collection_url }}" class="category-card">
          <div class="category-icon-wrap">🌾</div>
          <div class="category-name">Alimento Seco</div>
          <div class="category-count">Nutrición natural y completa</div>
          <div class="category-arrow">Ver más →</div>
        </a>

        <a href="{{ collections['gatos-humedo'].url | default: routes.all_products_collection_url }}" class="category-card">
          <div class="category-icon-wrap">🥩</div>
          <div class="category-name">Húmedo</div>
          <div class="category-count">Patés, gelatinas y latas</div>
          <div class="category-arrow">Ver más →</div>
        </a>

        <a href="{{ collections['gatos-premios'].url | default: routes.all_products_collection_url }}" class="category-card">
          <div class="category-icon-wrap">⭐</div>
          <div class="category-name">Premios</div>
          <div class="category-count">Snacks y golosinas</div>
          <div class="category-arrow">Ver más →</div>
        </a>

        <a href="{{ collections['gatos-suplementos'].url | default: routes.all_products_collection_url }}" class="category-card">
          <div class="category-icon-wrap">💊</div>
          <div class="category-name">Suplementos</div>
          <div class="category-count">Vitaminas y cuidado especial</div>
          <div class="category-arrow">Ver más →</div>
        </a>

      </div>
    </div>

    <!-- Panel PERROS -->
    <div class="tab-panel dog-theme" id="tab-perros" role="tabpanel" aria-labelledby="btn-perros">
      <div class="categories-grid">

        <a href="{{ collections['perros-croquetas'].url | default: routes.all_products_collection_url }}" class="category-card">
          <div class="category-icon-wrap">🥣</div>
          <div class="category-name">Croquetas</div>
          <div class="category-count">Alimento seco balanceado</div>
          <div class="category-arrow">Ver más →</div>
        </a>

        <a href="{{ collections['perros-alimento-seco'].url | default: routes.all_products_collection_url }}" class="category-card">
          <div class="category-icon-wrap">🌾</div>
          <div class="category-name">Alimento Seco</div>
          <div class="category-count">Nutrición natural y completa</div>
          <div class="category-arrow">Ver más →</div>
        </a>

        <a href="{{ collections['perros-humedo'].url | default: routes.all_products_collection_url }}" class="category-card">
          <div class="category-icon-wrap">🥩</div>
          <div class="category-name">Húmedo</div>
          <div class="category-count">Latas y bolsitas premium</div>
          <div class="category-arrow">Ver más →</div>
        </a>

        <a href="{{ collections['perros-premios'].url | default: routes.all_products_collection_url }}" class="category-card">
          <div class="category-icon-wrap">⭐</div>
          <div class="category-name">Premios</div>
          <div class="category-count">Snacks y golosinas naturales</div>
          <div class="category-arrow">Ver más →</div>
        </a>

        <a href="{{ collections['perros-suplementos'].url | default: routes.all_products_collection_url }}" class="category-card">
          <div class="category-icon-wrap">💊</div>
          <div class="category-name">Suplementos</div>
          <div class="category-count">Articulaciones, piel y pelaje</div>
          <div class="category-arrow">Ver más →</div>
        </a>

      </div>
    </div>

  </div>
</section>
