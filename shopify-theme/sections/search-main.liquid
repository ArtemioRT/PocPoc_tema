<section class="search-page">
  <div class="container">

    <div class="search-hero">
      <p class="section-label">Buscar</p>
      <h1 class="section-title">¿Qué estás buscando?</h1>
      <p class="section-desc" style="margin: 0 auto;">Encuentra alimentos, premios, suplementos y más para tu mascota.</p>

      <div class="search-form">
        <form action="/search" method="get" role="search">
          <div style="display:flex; gap:10px; width:100%;">
            <input
              type="search"
              name="q"
              class="search-input"
              placeholder="Busca croquetas, premios, suplementos..."
              value="{{ search.terms | escape }}"
              aria-label="Buscar productos"
              autocorrect="off"
              autocapitalize="off"
            >
            <button type="submit" class="search-btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </button>
          </div>
        </form>
      </div>
    </div>

    {%- if search.performed -%}
      {%- if search.results_count == 0 -%}
        <div style="text-align:center; padding: 60px 0;">
          <div style="font-size:64px; margin-bottom:16px;">🔍</div>
          <h2 class="section-title">Sin resultados para "{{ search.terms }}"</h2>
          <p style="color: var(--gray); margin-bottom:28px;">Intenta con otros términos o explora nuestras categorías.</p>
          <div style="display:flex; gap:10px; justify-content:center; flex-wrap:wrap;">
            <a href="{{ collections['gatos'].url | default: routes.all_products_collection_url }}" class="btn-primary" style="background: var(--terracotta); color:white;">🐱 Ver Gatos</a>
            <a href="{{ collections['perros'].url | default: routes.all_products_collection_url }}" class="btn-primary" style="background: var(--forest); color:white;">🐶 Ver Perros</a>
          </div>
        </div>
      {%- else -%}
        <p style="font-size:14px; color:var(--gray); margin-bottom:28px;">{{ search.results_count }} resultado{% if search.results_count != 1 %}s{% endif %} para "<strong>{{ search.terms }}</strong>"</p>
        <div class="products-grid" style="grid-template-columns: repeat(4,1fr);">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              <article class="product-card">
                <div class="product-image-wrap">
                  {%- if item.featured_image -%}
                    <img src="{{ item.featured_image | img_url: '400x400' }}" alt="{{ item.title | escape }}" loading="lazy">
                  {%- else -%}
                    <span style="font-size:72px">🐾</span>
                  {%- endif -%}
                  <div class="product-pet-tag">{%- if item.tags contains 'gatos' -%}🐱{%- else -%}🐶{%- endif -%}</div>
                  <button class="product-quick-add">+</button>
                </div>
                <div class="product-info">
                  <div class="product-meta"><span class="product-category">{{ item.type }}</span><span class="product-rating">★ 4.8</span></div>
                  <a href="{{ item.url }}" class="product-name">{{ item.title }}</a>
                  <div class="product-price-row">
                    <span class="product-price">{{ item.price | money }}</span>
                    <button class="add-to-cart-mini">+ Agregar</button>
                  </div>
                </div>
              </article>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}

  </div>
</section>
