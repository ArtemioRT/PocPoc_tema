<section class="hero">
  <div class="container">
    <div class="hero-card">
      <div>
        <div class="badges">
          {% for badge in section.blocks %}
            <span class="badge">{{ badge.settings.text }}</span>
          {% endfor %}
        </div>
        <h1>{{ section.settings.heading }}</h1>
        <p>{{ section.settings.subheading }}</p>
      </div>
      <div class="hero-cta">
        <a class="btn btn-primary" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
        <a class="btn btn-ghost" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo",
      "default": "Nutricion completa para Gatos y Perros"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtitulo",
      "default": "Explora categorias claras, compra rapido y descubre recomendaciones segun cada etapa de vida."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Boton principal",
      "default": "Comprar para Gatos"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Enlace principal"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Boton secundario",
      "default": "Comprar para Perros"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Enlace secundario"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Entrega 24-48h"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "badge" },
        { "type": "badge" },
        { "type": "badge" }
      ]
    }
  ]
}
{% endschema %}
