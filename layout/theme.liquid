<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_accent }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@500;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
      :root {
        --color-bg: {{ settings.color_bg }};
        --color-accent: {{ settings.color_accent }};
        --color-accent-2: {{ settings.color_accent_2 }};
      }
    </style>
    {{ content_for_header }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    {{ 'theme.js' | asset_url | script_tag }}
    <title>{{ page_title }}{% if current_tags %} – {{ current_tags | join: ', ' }}{% endif %}{% if current_page != 1 %} – {{ 'general.pagination.page' | t: page: current_page }}{% endif %}{% unless page_title contains shop.name %} – {{ shop.name }}{% endunless %}</title>
  </head>
  <body class="theme-body">
    <a class="skip-link" href="#MainContent">Saltar al contenido</a>
    {% section 'header' %}
    <main id="MainContent" class="main">
      {{ content_for_layout }}
    </main>
    {% section 'footer' %}
  </body>
</html>
